{
  "name": "@bsv/ts-stack",
  "private": true,
  "description": "BSV TypeScript monorepo — SDK, Wallet, Network, Overlay, Messaging, Middleware, Helpers",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r run clean",
    "sync-versions": "node scripts/sync-versions.mjs",
    "check-versions": "node scripts/check-versions.mjs",
    "conformance": "node conformance/runner/src/runner.js",
    "docs:asyncapi": "node scripts/generate-asyncapi-html.mjs",
    "docs:dev": "pnpm --filter docs-site dev",
    "docs:build": "pnpm --filter docs-site build",
    "docs:preview": "pnpm --filter docs-site preview"
  },
  "devDependencies": {
    "@asyncapi/generator": "^2.8.4",
    "@asyncapi/html-template": "^3.5.6"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "jest-environment-node": "^30.3.0",
      "jest-mock": "^30.3.0"
    }
  }
}
