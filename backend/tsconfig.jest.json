{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": ["jest", "node"],
    "lib": ["ES2020", "DOM"]
  },
  "include": [
    "src/**/*",
    "src/**/__tests/**/*",
    "**/*.test.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
