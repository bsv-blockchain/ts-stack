{
  "name": "@bsv/wallet-relay",
  "version": "0.1.1",
  "description": "BSV mobile wallet relay — relay server and pairing client",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "wallet-relay": "./bin/init.mjs"
  },
  "files": [
    "dist",
    "bin",
    "template"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.cjs"
  },
  "peerDependencies": {
    "@bsv/sdk": "^2.1.0",
    "express": ">=4.0.0",
    "qrcode": ">=1.5.0",
    "react": ">=17.0.0",
    "ws": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "qrcode": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "ws": {
      "optional": true
    }
  },
  "devDependencies": {
    "@bsv/sdk": "^2.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.8.0",
    "@types/qrcode": "^1.5.0",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.5.0",
    "express": "^5.2.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "qrcode": "^1.5.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ts-jest": "^29.4.6",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "ws": "^8.20.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bsv-blockchain/ts-stack.git",
    "directory": "packages/wallet/ts-wallet-relay"
  },
  "bugs": {
    "url": "https://github.com/bsv-blockchain/ts-stack/issues"
  },
  "homepage": "https://github.com/bsv-blockchain/ts-stack/tree/main/packages/wallet/ts-wallet-relay#readme"
}
