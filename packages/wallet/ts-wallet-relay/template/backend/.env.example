# Copy this file to .env and fill in your values.

# Port the Express server listens on.
PORT=3000

# Public WebSocket address of this server — used in the QR deeplink so the
# mobile app knows where to connect. Must start with ws:// or wss://.
# In production: wss://your-domain.com
RELAY_URL=ws://localhost:3000

# Allowed CORS origin — must match the URL where the desktop frontend is served.
# In production: https://your-domain.com
ORIGIN=http://localhost:5173

# Backend wallet private key (hex format). Required — the mobile derives its
# ECDH shared secret from the identity key embedded in the QR code, so this
# key must stay the same across restarts.
# Generate: node --input-type=commonjs -e "const {PrivateKey}=require('@bsv/sdk'); console.log(PrivateKey.fromRandom().toHex())"
# Keep this secret — never commit it to source control.
WALLET_PRIVATE_KEY=your-private-key-in-hex-format
