{
  "name": "@bsv/402-pay",
  "version": "0.1.3",
  "description": "BRC-121 Simple 402 Payments — server middleware and client for BSV micropayments over HTTP",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "bsv",
    "402",
    "payment",
    "micropayments",
    "brc-121",
    "middleware"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bsv-blockchain/ts-stack.git",
    "directory": "packages/middleware/402-pay"
  },
  "author": "Deggen <d.kellenschwiler@bsvassociation.org>",
  "license": "SEE LICENSE IN LICENSE",
  "peerDependencies": {
    "@bsv/sdk": "^2.1.0"
  },
  "devDependencies": {
    "@bsv/sdk": "^2.1.0",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.3"
  },
  "bugs": {
    "url": "https://github.com/bsv-blockchain/ts-stack/issues"
  },
  "homepage": "https://github.com/bsv-blockchain/ts-stack/tree/main/packages/middleware/402-pay#readme"
}
