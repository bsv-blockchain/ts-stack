{
  "name": "@bsv/auth-express-middleware",
  "version": "2.0.5",
  "description": "BSV Blockchain mutual-authentication express middleware",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bsv-blockchain/ts-stack.git",
    "directory": "packages/middleware/auth-express-middleware"
  },
  "type": "module",
  "main": "dist/cjs/mod.js",
  "module": "dist/esm/mod.js",
  "types": "dist/types/mod.d.ts",
  "files": [
    "dist",
    "src",
    "docs",
    "mod.ts",
    "LICENSE.txt"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/mod.d.ts",
      "import": "./dist/esm/mod.js",
      "require": "./dist/cjs/mod.js"
    },
    "./*.ts": {
      "types": "./dist/types/src/*.d.ts",
      "import": "./dist/esm/src/*.js",
      "require": "./dist/cjs/src/*.js"
    }
  },
  "scripts": {
    "test": "npm run build && jest --runInBand",
    "test:watch": "npm run build && jest --watch",
    "test:coverage": "npm run build && jest --coverage",
    "lint": "ts-standard --fix src/**/*.ts",
    "build": "tsc -b && tsconfig-to-dual-package tsconfig.cjs.json",
    "dev": "tsc -b -w",
    "prepublish": "npm run build",
    "doc": "ts2md --inputFilename=mod.ts --outputFilename=API.md --filenameSubstring=API --firstHeadingLevel=1"
  },
  "bugs": {
    "url": "https://github.com/bsv-blockchain/ts-stack/issues"
  },
  "homepage": "https://github.com/bsv-blockchain/ts-stack/tree/main/packages/middleware/auth-express-middleware#readme",
  "keywords": [
    "BSV",
    "Blockchain",
    "Mutual-Authentication",
    "Express",
    "Middleware"
  ],
  "author": "BSV Blockchain Association",
  "license": "SEE LICENSE IN LICENSE.txt",
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/mime-types": "^3.0.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.9",
    "ts-standard": "^12.0.2",
    "ts2md": "^0.2.0",
    "tsconfig-to-dual-package": "^1.2.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@bsv/sdk": "^2.1.0",
    "express": "^5.2.1"
  }
}
