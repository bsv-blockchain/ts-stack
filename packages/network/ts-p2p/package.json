{
  "name": "@bsv/teranode-listener",
  "version": "1.0.3",
  "description": "An npm package to subscribe to Teranode P2P topics in a private DHT network and log messages",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@bsv/sdk": "^2.0.14",
    "@chainsafe/libp2p-gossipsub": "^14.1.1",
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@libp2p/bootstrap": "^12.0.19",
    "@libp2p/crypto": "^5.1.7",
    "@libp2p/identify": "^4.1.3",
    "@libp2p/interface": "^3.2.2",
    "@libp2p/kad-dht": "^16.2.4",
    "@libp2p/peer-id": "^6.0.8",
    "@libp2p/ping": "^3.1.3",
    "@libp2p/pnet": "^3.0.19",
    "@libp2p/pubsub-peer-discovery": "^12.0.0",
    "@libp2p/tcp": "^11.0.18",
