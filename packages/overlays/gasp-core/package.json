{
  "name": "@bsv/gasp",
  "version": "1.2.2",
  "type": "module",
  "description": "Graph Aware Sync Protocol",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bsv-blockchain/ts-stack.git",
    "directory": "packages/overlays/gasp-core"
  },
  "homepage": "https://github.com/bsv-blockchain/ts-stack/tree/main/packages/overlays/gasp-core#readme",
  "bugs": {
    "url": "https://github.com/bsv-blockchain/ts-stack/issues"
  },
  "main": "dist/cjs/mod.js",
  "module": "dist/esm/mod.js",
  "types": "dist/types/mod.d.ts",
  "files": [
    "dist",
    "src",
    "mod.ts",
    "LICENSE.txt"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/mod.d.ts",
      "import": "./dist/esm/mod.js",
      "require": "./dist/cjs/mod.js"
    },
    "./*.ts": {
      "types": "./dist/types/src/*.d.ts",
      "import": "./dist/esm/src/*.js",
      "require": "./dist/cjs/src/*.js"
    }
  },
  "scripts": {
    "test": "npm run build && jest",
    "test:watch": "npm run build && jest --watch",
    "test:coverage": "npm run build && jest --coverage",
    "lint": "ts-standard --fix src/**/*.ts",
    "build": "tsc -b && tsconfig-to-dual-package tsconfig.cjs.json",
    "dev": "tsc -b -w",
    "prepublish": "npm run build",
    "doc": "ts2md --inputFilename=mod.ts --outputFilename=API.md --filenameSubstring=API --firstHeadingLevel=1"
  },
  "keywords": [
    "blockchain",
    "protocol",
    "sync",
    "transaction",
    "GASP"
  ],
  "author": "BSV Blockchain Association",
  "license": "SEE LICENSE IN LICENSE.txt",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-standard": "^12.0.2",
    "ts2md": "^0.2.0",
    "tsconfig-to-dual-package": "^1.2.0",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "@bsv/sdk": "^2.0.14"
  }
}
