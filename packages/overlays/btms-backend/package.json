{
  "name": "@bsv/btms-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "BTMS Backend",
  "module": "dist/esm/mod.js",
  "types": "dist/types/mod.d.ts",
  "files": [
    "dist",
    "src",
    "mod.ts",
    "LICENSE.txt"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/mod.d.ts",
      "import": "./dist/esm/mod.js"
    },
    "./*.ts": {
      "types": "./dist/types/src/*.d.ts",
      "import": "./dist/esm/src/*.js"
    }
  },
  "scripts": {
    "test": "jest",
    "test:build": "npm run build && jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "ts-standard --fix src/**/*.ts",
    "build": "tsc -b",
    "prepublish": "npm run build",
    "doc": "ts2md --inputFilename=mod.ts --outputFilename=API.md --filenameSubstring=API --firstHeadingLevel=1"
  },
  "author": "BSV Association",
  "license": "SEE LICENSE IN LICENSE.txt",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.1.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-standard": "^12.0.2",
    "ts2md": "^0.2.0",
    "tsconfig-to-dual-package": "^1.2.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@bsv/overlay": "^2.0.2",
    "@bsv/sdk": "^2.1.0",
    "mongodb": "^7.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bsv-blockchain/ts-stack.git",
    "directory": "packages/overlays/btms-backend"
  },
  "bugs": {
    "url": "https://github.com/bsv-blockchain/ts-stack/issues"
  },
  "homepage": "https://github.com/bsv-blockchain/ts-stack/tree/main/packages/overlays/btms-backend#readme"
}
