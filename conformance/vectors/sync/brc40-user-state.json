        },
        "incoming": {
          "outputId": 555,
          "userId": 7,
          "transactionId": 42,
          "vout": 0,
          "satoshis": 5000,
          "spendable": false,
          "spentBy": null,
          "created_at": "2026-04-23T12:00:00.000Z",
          "updated_at": "2026-04-23T12:45:00.000Z"
