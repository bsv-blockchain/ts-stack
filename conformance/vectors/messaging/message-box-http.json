    {
      "id": "messaging.messagebox-http.getpermission.1",
      "description": "getPermission for sender+box",
      "input": {
        "method": "GET",
        "path": "/permissions/get?messageBox=inbox&sender=028d37b941208cd6b8a4c28288eda5f2f16c2b3ab0fcb6d13c18b47fe37b971fc1",
        "headers": {
          "x-bsv-auth-identity-key": "02c6047f9441ed7d6d3045406e95c07cd85c778e4b8cef3ca7abac09b95c709ee5"
        },
        "queryParams": {
          "messageBox": "inbox",
          "sender": "028d37b941208cd6b8a4c28288eda5f2f16c2b3ab0fcb6d13c18b47fe37b971fc1"
        }
      },
      "expected": {
        "status": 200,
        "body": {
          "status": "success",
          "permission": {
            "messageBox": "inbox",
            "sender": "028d37b941208cd6b8a4c28288eda5f2f16c2b3ab0fcb6d13c18b47fe37b971fc1",
            "recipientFee": 500
          }
        }
      },
      "tags": ["messaging", "getPermission", "happy-path"]
    },
