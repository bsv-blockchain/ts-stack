      },
      "tags": ["messaging", "acknowledgeMessage", "multi"]
    },
    {
      "id": "messaging.messagebox-http.acknowledgemessage.3",
      "description": "acknowledgeMessage non-existent messageIds succeeds idempotently",
      "input": {
        "method": "POST",
        "path": "/acknowledgeMessage",
        "headers": {
          "Content-Type": "application/json",
          "x-bsv-auth-identity-key": "02c6047f9441ed7d6d3045406e95c07cd85c778e4b8cef3ca7abac09b95c709ee5"
        },
        "body": {
          "messageBox": "inbox",
          "messageIds": ["nonexistent-id-xyz"]
        }
      },
      "expected": {
        "status": 200,
        "body": { "status": "success" }
      },
      "tags": ["messaging", "acknowledgeMessage", "idempotent"]
    },
    {
      "id": "messaging.messagebox-http.acknowledgemessage.4",
      "description": "acknowledgeMessage without auth returns 401",
      "input": {
        "method": "POST",
        "path": "/acknowledgeMessage",
        "headers": { "Content-Type": "application/json" },
        "body": { "messageBox": "inbox", "messageIds": ["msg-001"] }
