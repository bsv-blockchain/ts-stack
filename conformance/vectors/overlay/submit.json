    {
      "id": "overlay.submit.12",
      "description": "Error response shape — 400 response must contain status=error and message string",
      "input": {
        "method": "POST",
        "path": "/submit",
        "headers": {
          "Content-Type": "application/octet-stream"
        },
        "body_hex": ""
