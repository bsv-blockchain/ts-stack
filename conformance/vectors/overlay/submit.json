      "tags": ["overlay", "submit", "happy-path", "coinstake", "steak"]
    },
    {
      "id": "overlay.submit.11",
      "description": "Submit with Content-Type application/json instead of octet-stream — server must return 400",
      "input": {
        "method": "POST",
        "path": "/submit",
        "headers": {
          "Content-Type": "application/json",
          "x-topics": "[\"tm_ship\"]"
        },
        "body_hex": "0100beef01010000000001a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b20000000000ffffffff0100e1f50500000000001976a914f54a5851e9372b87810a8e60cdd2e7cfd80b6e5388ac00000000"
      },
      "expected": {
        "status": 400,
        "body": {
          "status": "error"
