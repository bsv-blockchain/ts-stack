    {
      "id": "overlay.submit.6",
      "description": "Submit with completely empty body — server must return 400 Bad Request",
      "input": {
        "method": "POST",
        "path": "/submit",
        "headers": {
          "Content-Type": "application/octet-stream",
          "x-topics": "[\"tm_ship\"]"
        },
        "body_hex": ""
      },
      "expected": {
        "status": 400,
        "body": {
          "status": "error"
        }
      },
      "tags": ["overlay", "submit", "error-case", "empty-body"]
    },
    {
      "id": "overlay.submit.7",
      "description": "Submit with x-topics containing a non-existent topic manager — engine routes, topic returns empty admission",
      "input": {
        "method": "POST",
        "path": "/submit",
        "headers": {
          "Content-Type": "application/octet-stream",
          "x-topics": "[\"tm_unknown_xyz\"]"
        },
        "body_hex": "0100beef01010000000001a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b20000000000ffffffff0100e1f50500000000001976a914f54a5851e9372b87810a8e60cdd2e7cfd80b6e5388ac00000000"
      },
      "expected": {
        "status": 400,
        "body": {
          "status": "error"
        }
      },
      "tags": ["overlay", "submit", "error-case", "unknown-topic"]
    },
    {
      "id": "overlay.submit.8",
      "description": "Submit BEEF with off-chain values prefix (x-includes-off-chain-values: true) — valid BEEF after varint-delimited prefix",
      "input": {
        "method": "POST",
        "path": "/submit",
        "headers": {
          "Content-Type": "application/octet-stream",
          "x-topics": "[\"tm_ship\"]",
          "x-includes-off-chain-values": "true"
        },
        "body_hex": "04deadbeef0100beef01010000000001a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b20000000000ffffffff0100e1f50500000000001976a914f54a5851e9372b87810a8e60cdd2e7cfd80b6e5388ac00000000",
        "note": "Body: varint(4) + 4 off-chain bytes + BEEF bytes"
      },
      "expected": {
        "status": 200,
        "body": {
          "tm_ship": {
            "outputsToAdmit": [0]
          }
        }
      },
      "tags": ["overlay", "submit", "happy-path", "off-chain-values"]
    },
    {
      "id": "overlay.submit.9",
      "description": "Submit with x-topics as a non-JSON string — server must return 400 Bad Request",
      "input": {
        "method": "POST",
        "path": "/submit",
        "headers": {
          "Content-Type": "application/octet-stream",
          "x-topics": "tm_ship"
        },
        "body_hex": "0100beef01010000000001a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b20000000000ffffffff0100e1f50500000000001976a914f54a5851e9372b87810a8e60cdd2e7cfd80b6e5388ac00000000"
      },
      "expected": {
        "status": 400,
        "body": {
          "status": "error"
        }
      },
      "tags": ["overlay", "submit", "error-case", "malformed-header"]
    },
    {
      "id": "overlay.submit.10",
      "description": "Submit BEEF with coinstake outputs — STEAK includes coinstakeOutputsToRetain",
      "input": {
        "method": "POST",
        "path": "/submit",
        "headers": {
          "Content-Type": "application/octet-stream",
