        "sender_private_key_hex": "d5a5f70b373ce164998dff7ecd93260d7e80356d3d10abf928fb267f0a6c7be6",
        "recipient_public_key_hex": "02745623f4e5de046b6ab59ce837efa1a959a8f28286ce9154a4781ec033b85029",
