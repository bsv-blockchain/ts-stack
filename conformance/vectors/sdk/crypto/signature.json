      ]
    },
    {
      "id": "sig-compact-010",
      "description": "toCompact with recovery=3, compressed=true has first byte 0x34 (52 decimal)",
      "input": {
        "privkey_hex": "1e5edd45de6d22deebef4596b80444ffcc29143839c1dce18db470e25b4be7b5",
        "message_hex": "deadbeef",
        "k": "drbg",
        "recovery": 3,
        "compressed": true
      },
      "expected": {
