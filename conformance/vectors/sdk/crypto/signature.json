    {
      "id": "sig-compact-011",
      "description": "toCompact with recovery=0, compressed=true has compact first byte formula: 31 = 27 + 4 + recovery",
      "input": {
        "privkey_hex": "2222222222222222222222222222222222222222222222222222222222222222",
        "message_hex": "cafebabe",
        "k": "drbg",
        "recovery": 0,
        "compressed": true
      },
      "expected": {
        "compact_hex": "1f024eb1ae149d315b0fb68b623cf455086aba5c8b92e068682c1ca12dfcdfd6527dbe86af62a372324b9ec4a35f777227d012b6c042ca800327e16b446d1bc5f3",
        "first_byte": 31
      },
      "tags": [
