{
  "$schema": "../../../schema/vector.schema.json",
  "id": "wallet.brc100.relinquishcertificate",
  "name": "BRC-100 relinquishcertificate",
  "brc": [
    "BRC-100"
  ],
  "version": "2.0.1",
  "reference_impl": "@bsv/sdk@2.0.14 + wallet-toolbox",
  "parity_class": "required",
  "vectors": [
    {
      "id": "wallet.brc100.relinquishcertificate.1",
      "description": "relinquishCertificate happy path",
      "input": {
        "args": {
          "type": "AGFjZXJ0dHlwZQAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA==",
          "serialNumber": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=",
          "certifier": "0279be667ef9dcbbac55a06295ce870b07029bfcdb2dce28d959f2815b16f81798"
        }
      },
      "expected": {
        "relinquished": true
      },
      "tags": [
        "brc-100",
        "relinquishCertificate",
        "happy-path"
      ],
      "parity_class": "intended",
      "skip_reason": "Requires pre-existing certificate in storage. Fresh wallet has no certs."
    },
    {
      "id": "wallet.brc100.relinquishcertificate.2",
      "description": "relinquishCertificate with originator",
      "input": {
        "args": {
          "type": "AGFjZXJ0dHlwZQAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA==",
          "serialNumber": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=",
          "certifier": "0279be667ef9dcbbac55a06295ce870b07029bfcdb2dce28d959f2815b16f81798"
        },
        "originator": "app.example.com"
      },
      "expected": {
        "relinquished": true
      },
      "tags": [
        "brc-100",
        "relinquishCertificate",
        "originator"
      ],
      "parity_class": "intended",
      "skip_reason": "Requires pre-existing certificate in storage. Fresh wallet has no certs."
    },
    {
      "id": "wallet.brc100.relinquishcertificate.3",
      "description": "relinquishCertificate certificate not found",
      "input": {
        "args": {
          "type": "AGFjZXJ0dHlwZQAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA==",
          "serialNumber": "ZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZ=",
          "certifier": "0279be667ef9dcbbac55a06295ce870b07029bfcdb2dce28d959f2815b16f81798"
        }
      },
      "expected": {
        "error": true,
        "code": "ERR_CERTIFICATE_NOT_FOUND"
      },
      "tags": [
        "brc-100",
        "relinquishCertificate",
        "error"
      ]
    },
    {
