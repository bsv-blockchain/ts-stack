    {
      "id": "wallet.storage.adapterconformance.12",
      "description": "POST /sync/chunk — export a sync chunk since a given timestamp",
      "input": {
        "method": "POST",
        "path": "/storage/v1/sync/chunk",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer brc103-session-token-abc123"
        },
        "body": {
          "identityKey": "02a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2",
          "fromStorageIdentityKey": "03b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3",
          "since": "2026-01-01T00:00:00.000Z",
          "paged": {
            "limit": 100,
            "offset": 0
          }
        }
      },
      "expected": {
        "status": 200,
        "body": {
          "users": [],
          "transactions": [],
          "outputs": [],
          "outputBaskets": [],
          "provenTxs": [],
          "provenTxReqs": [],
          "syncStates": []
        },
        "schema_note": "SyncChunk: { users?, transactions?, outputs?, outputBaskets?, provenTxs?, provenTxReqs?, syncStates? }"
      },
      "tags": ["wallet", "storage", "happy-path", "sync", "chunk"]
    },
    {
      "id": "wallet.storage.adapterconformance.13",
      "description": "POST /sync/state — findOrInsertSyncState creates new state record on first call",
      "input": {
        "method": "POST",
        "path": "/storage/v1/sync/state",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer brc103-session-token-abc123"
        },
        "body": {
          "storageIdentityKey": "03b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3",
          "storageName": "remote-wallet-storage"
        }
      },
      "expected": {
        "status": 200,
        "body": {
          "syncState": {
            "syncStateId": 1,
            "userId": 1,
            "storageIdentityKey": "03b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3",
            "storageName": "remote-wallet-storage",
            "status": "unknown",
            "init": false,
            "refNum": "ref-001",
            "syncMap": "{}"
          },
          "isNew": true
        },
        "schema_note": "FindOrInsertSyncStateResult: { syncState: TableSyncState, isNew: boolean }"
      },
      "tags": ["wallet", "storage", "happy-path", "sync", "sync-state", "find-or-insert"]
    },
