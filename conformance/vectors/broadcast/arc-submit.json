          "status": 404
        },
        "schema_note": "ArcErrorResponse: { detail?, status?, title?, type?, instance? }"
      },
      "tags": ["broadcast", "arc", "error-case", "not-found", "404"]
    },
    {
      "id": "broadcast.arcsubmit.14",
      "description": "ARC Merkle callback POST /arc-ingest — complete payload with all fields",
      "input": {
        "method": "POST",
        "path": "/arc-ingest",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer callback-secret-token-xyz789"
        },
        "body": {
          "txid": "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2",
          "merklePath": "fe8a6a0c000c04fde80b0011774f01d26412f0d16ea3f0447be0b5ebec67b0782e321a7a01cbdf7f734e30fde90b02004e53753e3fe4667073063a17987292cfdea278824e9888e52180581d7188d8",
          "blockHeight": 813706,
          "blockHash": "000000000000000001e4f0ac0b3e17e6a3f50c3d8ce1a1ccbdb71e5c9d4e2b8",
          "timestamp": "2026-05-01T12:00:00.000Z"
        }
      },
      "expected": {
        "status": 200,
        "body": {
          "status": "success",
          "message": "Merkle proof processed"
        }
      },
      "tags": ["broadcast", "arc", "callback", "merkle-proof", "happy-path"]
    },
    {
      "id": "broadcast.arcsubmit.15",
      "description": "ARC error response shape — all error responses must have detail or message field",
      "input": {
        "method": "POST",
        "path": "/v1/tx",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {}
      },
      "expected": {
        "status_oneof": [400, 401, 422],
        "body_schema": "ArcErrorResponse",
        "schema_note": "ArcErrorResponse: { txid?, detail?, status?: int, title?, type?, instance?, extraInfo? } — at least one of detail or title required"
      },
      "tags": ["broadcast", "arc", "error-case", "error-shape"]
    },
    {
      "id": "broadcast.arcsubmit.16",
      "description": "Submit transaction rate-limited — ARC returns 429 Too Many Requests",
      "input": {
        "method": "POST",
        "path": "/v1/tx",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer test-api-key-abc123"
        },
        "body": {
          "rawTx": "0100000001f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1000000006a00ffffffff0100e1f50500000000001976a914f54a5851e9372b87810a8e60cdd2e7cfd80b6e5388ac00000000"
        }
      },
      "expected": {
        "status": 429,
        "body": {
          "title": "Too Many Requests",
          "status": 429
        }
      },
