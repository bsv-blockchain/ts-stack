NODE_ENV=development
ENABLE_NGINX=false
HTTP_PORT=3998
BSV_NETWORK=test                                  # main | test | teratest | mock
SERVER_PRIVATE_KEY="bffe0d7a3f7effce2b3511323c6cca1df1649e41a336a8b603194d53287ad285" # Example private key
KNEX_DB_CONNECTION={"port":3306,"host":"mysql","user":"root","password":"rootPass","database":"wallet_storage"}

# --- Optional ---

# Fee model used when constructing outgoing transactions
FEE_MODEL={"model":"sat/kb","value":1}

# Server commission per request (satoshis); requires COMMISSION_PUBLIC_KEY when > 0
COMMISSION_FEE=0
# COMMISSION_PUBLIC_KEY=

# ARC (transaction broadcaster) — applies only for non-mock chains
# ARC_URL=https://arcade-v2-us-1.bsvblockchain.tech
# ARC_API_KEY=...                                 # API key for ARC; overrides TAAL_API_KEY in arcConfig
# ARC_CALLBACK_TOKEN=...                          # Required to enable TaskArcSSE proof-callback subscription
# TAAL_API_KEY=...                                # Legacy alias — populates both servOpts.taalApiKey and arcConfig.apiKey

# v3 schema cutover
# v3 is the default canonical schema. Fresh installs (empty `transactions` table) are
# initialized into the v3 layout automatically at boot — no flag required.
# Set LEGACY_UPGRADE=true ONLY when upgrading an existing v2 database with real legacy
# data, AFTER taking a backup and reading @bsv/wallet-toolbox docs/CUTOVER_RUNBOOK.md.
# Server refuses to boot on a legacy-populated DB without this flag.
# Alternative: leave unset and run `npm run cutover` during a maintenance window, then
# restart the server (StorageKnex._postCutoverCache initializes once at makeAvailable).
# LEGACY_UPGRADE=true
