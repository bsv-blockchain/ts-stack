    "twilio": "^5.4.4"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^4",
    "@types/jest": "^30.0.0",
    "@types/node": "^18.15.0",
    "@types/sqlite3": "^3.1.8",
    "body-parser": "^2.2.2",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.1",
